{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@screens/*": ["src/screens/*"],
      "@stores/*": ["src/stores/*"],
      "@services/*": ["src/services/*"],
      "@hooks/*": ["src/hooks/*"],
      "@utils/*": ["src/utils/*"],
      "@theme/*": ["src/theme/*"],
      "@i18n/*": ["src/i18n/*"],
      "@types/*": ["src/types/*"],
      "@navigation/*": ["src/navigation/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "*.d.ts"],
  "exclude": ["node_modules"]
}
